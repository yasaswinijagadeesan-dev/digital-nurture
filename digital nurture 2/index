<!DOCTYPE html>
<html>
<head>
    <title>Local Community Event Portal</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
        }

        .event-card {
            border: 1px solid #ccc;
            padding: 10px;
            margin: 10px 0;
        }

        .error {
            color: red;
        }

        #spinner {
            display: none;
        }
    </style>
</head>
<body>

<h1>Local Community Event Portal</h1>

<select id="categoryFilter">
    <option value="all">All</option>
    <option value="Music">Music</option>
    <option value="Workshop">Workshop</option>
</select>

<input type="text" id="searchBox" placeholder="Search Events">

<div id="spinner">Loading...</div>

<div id="eventContainer"></div>

<h2>Register</h2>

<form id="registrationForm">
    <input type="text" name="name" placeholder="Name"><br><br>
    <input type="email" name="email" placeholder="Email"><br><br>

    <select name="event">
        <option value="Music Fest">Music Fest</option>
        <option value="Baking Workshop">Baking Workshop</option>
    </select><br><br>

    <button type="submit" id="registerBtn">Submit</button>
</form>

<p id="message"></p>

<script src="main.js"></script>
<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

</body>
</html>